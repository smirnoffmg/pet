{
  "name": "@smirnoffmg/pet",
  "version": "0.1.0",
  "description": "Product Engineer Toolkit - agentic product development over markdown artifacts",
  "type": "module",
  "license": "MIT",
  "author": "Maksim Smirnov <smirnoffmg@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/smirnoffmg/pet.git"
  },
  "homepage": "https://github.com/smirnoffmg/pet#readme",
  "keywords": [
    "ai",
    "agents",
    "product-management",
    "llm",
    "cli",
    "product-development",
    "markdown"
  ],
  "bin": {
    "pet": "./dist/pet.js"
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "postinstall": "node scripts/postinstall.js",
    "pet": "node dist/pet.js",
    "validate": "tsx scripts/validate.ts",
    "test": "vitest run",
    "test:ollama": "PET_LLM_PROVIDER=ollama PET_LLM_MODEL=qwen3:8b vitest run tests/e2e",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.0",
    "@langchain/anthropic": "^1.4.0",
    "@langchain/aws": "^1.3.9",
    "@langchain/community": "^1.1.28",
    "@langchain/core": "^1.1.47",
    "@langchain/google-vertexai": "^2.1.31",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^13.1.0",
    "deepagents": "^1.10.2",
    "gray-matter": "^4.0.3",
    "ink": "^7.0.4",
    "ink-text-input": "^6.0.0",
    "neverthrow": "^8.2.0",
    "react": "^19.2.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@modelcontextprotocol/server-memory": "^2026.1.26",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.15",
    "esbuild": "^0.25.1",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.2.6"
  }
}
